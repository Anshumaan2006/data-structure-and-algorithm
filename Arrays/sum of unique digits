class Solution {
    public int sumOfUnique(int[] nums) {
        int[] freq = new int[101];  // values range 1–100
        
        // count frequency
        for (int num : nums) {
            freq[num]++;
        }
        
        int sum = 0;
        
        // add only unique numbers
        for (int i = 0; i <= 100; i++) {
            if (freq[i] == 1) {
                sum += i;   // add number, not frequency
            }
        }
        
        return sum;
    }
}
